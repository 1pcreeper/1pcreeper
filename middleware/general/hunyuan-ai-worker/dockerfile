# Use the official PyTorch image with CUDA 12.1 (Adjust if your GPU needs a different CUDA version)
FROM pytorch/pytorch:2.2.1-cuda12.1-cudnn8-runtime

# Set working directory
WORKDIR /app

# Install system dependencies required for OpenCV, 3D rendering, and Git
RUN apt-get update && apt-get install -y \
    git \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy your worker requirements and install them
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy your actual worker code
COPY src/ /app/src/

# Set the Python path so it finds your 'src' module
ENV PYTHONPATH=/app

# The ignition switch! >w<
CMD ["python", "-m", "src"]